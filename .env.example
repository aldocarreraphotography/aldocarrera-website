# Required ----------------------------------------------------------------
# The single password Aldo signs in with. Set this to something strong.
ADMIN_PASSWORD=change-me-to-a-strong-password

# 48+ random bytes, base64url. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=generate-a-random-secret-here

# Optional ----------------------------------------------------------------
# Token lifetime in seconds. Default 30 days.
# JWT_EXPIRES_IN=2592000

# Cap login attempts per IP per 5 minutes. Default 10.
# LOGIN_RATE_LIMIT=10
