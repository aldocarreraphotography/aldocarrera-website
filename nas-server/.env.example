# Copy this to .env and fill in the values.
# NEVER commit .env to git.

# A long random string — use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_HEX

# The admin password you use to log in
ADMIN_PASSWORD=REPLACE_WITH_YOUR_ADMIN_PASSWORD

# The public URL of this NAS server — no trailing slash.
# This is what gets stored in image blobPaths and what browsers fetch images from.
# Example: https://aldocarrera.synology.me or https://api.aldocarrera.com
PUBLIC_URL=https://YOUR_NAS_HOSTNAME

# Optional: override data/images directories (defaults to ./data and ./images inside the container)
# DATA_DIR=/app/data
# IMAGES_DIR=/app/images

# Optional: change port (default 3001)
# PORT=3001

# ---- Docker compose configuration ----
# Host paths mounted into the api container. Adjust to wherever your
# JSON data and image bytes live on the NAS.
DATA_HOST_PATH=/volume2/Ingesting 2/aldocarrera/data
IMAGES_HOST_PATH=/volume2/Ingesting 2/aldocarrera/images

# Cloudflare tunnel token (from one.dash.cloudflare.com → Networks → Tunnels).
# Keep this secret — never commit the real value.
CLOUDFLARED_TOKEN=REPLACE_WITH_CLOUDFLARE_TUNNEL_TOKEN
