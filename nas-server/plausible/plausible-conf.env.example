# Copy to plausible-conf.env and fill in.
# Generate SECRET_KEY_BASE with:  openssl rand -base64 64 | tr -d '\n'
# Generate POSTGRES_PASSWORD with: openssl rand -hex 24

BASE_URL=https://analytics.aldocarrera.com
SECRET_KEY_BASE=REPLACE_ME_64_BYTE_RANDOM_STRING
POSTGRES_PASSWORD=REPLACE_ME_POSTGRES_PASSWORD

# Internal — these refer to the docker-compose service names; don't change.
DATABASE_URL=postgres://postgres:REPLACE_ME_POSTGRES_PASSWORD@plausible_db:5432/plausible_db
CLICKHOUSE_DATABASE_URL=http://plausible_events_db:8123/plausible_events_db

# Optional: disable account registration once you've created yours
DISABLE_REGISTRATION=invite_only

# Optional SMTP (so password resets work). Reuse Resend SMTP if you want:
# MAILER_EMAIL=noreply@aldocarrera.com
# SMTP_HOST_ADDR=smtp.resend.com
# SMTP_HOST_PORT=465
# SMTP_USER_NAME=resend
# SMTP_USER_PWD=YOUR_RESEND_API_KEY
# SMTP_HOST_SSL_ENABLED=true
